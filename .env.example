# DownAria-API environment

# Required
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=pretty
YTDLP_BINARY=yt-dlp

# No authentication required - all APIs are public

# Optional: app mode
# ENV=development

# Optional: HTTP tuning
# HTTP_READ_TIMEOUT=15s
# HTTP_WRITE_TIMEOUT=5m
# HTTP_IDLE_TIMEOUT=60s

# Optional: extraction/cache tuning
# EXTRACT_TIMEOUT=45s
# EXTRACT_CACHE_TTL=10m
# EXTRACT_CACHE_DIR=
# YTDLP_CONCURRENT_FRAGMENTS=16

# Optional: runtime paths
# Ephemeral artifacts/jobs/downloads/merges default to OS temp: <temp>/downaria-api
# Persistent stats default to user local app data: <local-app-data>/DownAria-API/stats
# DOWNARIA_API_TEMP_DIR=
# DOWNARIA_API_STATS_DIR=

# Optional: artifact/job storage
# ARTIFACT_DIR=
# ARTIFACT_TTL=30m
# ARTIFACT_MAX_BYTES=2147483648
# JOB_DIR=
# JOB_TIMEOUT=30m
# WORKSPACE_TTL=30m

# Optional: limits/security
# MAX_DOWNLOAD_BYTES=935329792
# MAX_OUTPUT_BYTES=935329792
# MAX_MEDIA_DURATION=119m
# MEDIA_RATE_LIMIT=20
# MEDIA_RATE_BURST=20
# JOB_RATE_LIMIT=50
# JOB_RATE_BURST=50
# OUTBOUND_BLOCKED_CIDRS=
